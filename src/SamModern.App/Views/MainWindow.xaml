<Window x:Class="SamModern.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SAM Modern" Height="540" Width="900" MinHeight="480" MinWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Steam Achievement Manager — Modern" FontSize="24" FontWeight="SemiBold" />

        <Border Grid.Row="1" Margin="0,20,0,20" CornerRadius="10" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Text="MVP scaffold initialized." FontSize="18" FontWeight="Medium" Margin="0,0,0,8" />
                <TextBlock Text="Next: migrate legacy game list + achievements/stats workflows into this UI." TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StatusBar Grid.Row="2">
            <StatusBarItem Content="Mode: Safe by default" />
            <StatusBarItem Content="Network policy: allowlisted hosts" />
        </StatusBar>
    </Grid>
</Window>
